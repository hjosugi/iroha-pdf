{
  "name": "iroha-pdf",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run start --workspace @iroha-pdf/mobile",
    "dev:desktop": "npm run tauri:dev --workspace @iroha-pdf/desktop",
    "dev:desktop:web": "npm run dev --workspace @iroha-pdf/desktop",
    "build:desktop": "npm run build --workspace @iroha-pdf/desktop",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "~6.0.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
